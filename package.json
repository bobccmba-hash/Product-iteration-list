{
  "name": "ai-platform",
  "version": "0.1.2",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --webpack -H 127.0.0.1 -p 3459",
    "build": "next build",
    "start": "next start -H 127.0.0.1",
    "desktop:dev": "node electron/dev-runner.cjs",
    "desktop:build": "npm run build && node electron/prepare-standalone.cjs && electron-builder",
    "lint": "eslint"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.7.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^37.4.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "com.ai314.desktop",
    "productName": "AI-314",
    "asar": false,
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "electron/**",
      ".next/**",
      "!.next/cache/**",
      "!.next/dev/**",
      "public/**",
      "package.json",
      "next.config.ts"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bobccmba-hash",
        "repo": "Product-iteration-list"
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ]
    }
  }
}
